# StateID Environment Configuration

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://stateid:stateid_password@localhost:5432/stateid
REDIS_URL=redis://localhost:6379

# =============================================================================
# SERVICE CONFIGURATION
# =============================================================================
WRAPPER_SERVICE_URL=http://localhost:3001
CALENDAR_SERVICE_URL=http://localhost:3002
WRAPPER_SERVICE_PORT=3001
CALENDAR_SERVICE_PORT=3002

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
ENCRYPTION_KEY=your_32_character_encryption_key_here

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_oauth_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_oauth_client_secret

# Email Magic Links (optional)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@stateid.app

# =============================================================================
# GEO-LOCATION SERVICES
# =============================================================================
# Primary geo provider
MAXMIND_LICENSE_KEY=your_maxmind_license_key
MAXMIND_DATABASE_PATH=./data/GeoLite2-City.mmdb

# Secondary geo provider (for confidence scoring)
IP2LOCATION_API_KEY=your_ip2location_api_key

# Fallback geo provider
IPGEOLOCATION_API_KEY=your_ipgeolocation_api_key

# =============================================================================
# PERFORMANCE & RELIABILITY
# =============================================================================
# Wrapper service performance
REDIRECT_TIMEOUT_MS=200
BACKGROUND_RETRY_ATTEMPTS=3
FAIL_OPEN_THRESHOLD_MS=200

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# =============================================================================
# LOGGING & MONITORING
# =============================================================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# DataDog (optional)
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key

# Sentry (optional)
SENTRY_DSN=your_sentry_dsn

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
NODE_ENV=development
DEBUG=stateid:*

# Skip OAuth in development (use mock tokens)
SKIP_OAUTH_VERIFICATION=false

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================
# Uncomment and modify for production deployment

# WRAPPER_SERVICE_URL=https://api.stateid.app
# CALENDAR_SERVICE_URL=https://calendar.stateid.app
# DATABASE_URL=postgresql://username:password@prod-db:5432/stateid
# REDIS_URL=redis://prod-redis:6379
# NODE_ENV=production
# LOG_LEVEL=warn